{
  "name": "await-statuses",
  "version": "0.0.0",
  "type": "module",
  "description": "Wait for statuses on a given ref",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && ncc build lib/main.js && sed -i 's/\\x0D$//' ./dist/index.js",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freckle/await-statuses-action.git"
  },
  "author": "Freckle",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/github": "^7.0.0"
  },
  "devDependencies": {
    "@actions/glob": "^0.6.1",
    "@octokit/types": "^16.0.0",
    "@types/node": "^24.12.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
